---
import '../styles/global.css';
import { APP_NAME, APP_DESCRIPTION } from '../lib/constants';

interface Props {
  title?: string;
  description?: string;
}

const { title = APP_NAME, description = APP_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — {description}</title>
    <meta name="description" content={description} />
    
    <!-- Script Anti-Flash Dark Mode (FOUC Prevention) -->
    <script is:inline>
      (function() {
        try {
          const theme = localStorage.getItem('theme') ?? 
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col selection:bg-[#ffde59] selection:text-black dark:selection:bg-[#facc15] dark:selection:text-black">
    <slot />
  </body>
</html>
