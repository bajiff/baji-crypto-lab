---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ThemeToggle } from '../components/theme/ThemeToggle';
import { EncryptorPanel } from '../components/encryptor/EncryptorPanel';
import { APP_NAME, APP_DESCRIPTION } from '../lib/constants';
---

<BaseLayout title={APP_NAME} description={APP_DESCRIPTION}>
  {/* Header */}
  <header class="w-full border-b-4 border-black dark:border-white bg-white dark:bg-[#1a1a1a] px-4 py-4 sticky top-0 z-50 shadow-[0px_4px_0px_0px_#000000] dark:shadow-[0px_4px_0px_0px_#ffffff]">
    <div class="max-w-6xl mx-auto flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="w-11 h-11 rounded-xl border-3 border-black dark:border-white bg-[#ffde59] dark:bg-[#facc15] flex items-center justify-center shadow-[3px_3px_0px_0px_#000000] dark:shadow-[3px_3px_0px_0px_#ffffff] font-black text-xl rotate-[-3deg] hover:rotate-0 transition-transform">
          🔐
        </div>
        <div>
          <h1 class="font-black text-2xl tracking-tight uppercase text-black dark:text-white flex items-center gap-2">
            {APP_NAME}
          </h1>
          <p class="text-xs font-bold text-gray-600 dark:text-gray-400 hidden sm:block">
            {APP_DESCRIPTION}
          </p>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <a
          href="/about"
          class="px-3.5 py-2 rounded-xl border-3 border-black dark:border-white bg-[#c084fc] dark:bg-[#a855f7] text-black dark:text-white font-black text-xs shadow-[3px_3px_0px_0px_#000000] dark:shadow-[3px_3px_0px_0px_#ffffff] hover:translate-x-[-1px] hover:translate-y-[-1px] transition-all flex items-center gap-1.5"
          title="Baca penjelasan edukatif sejarah & cara kerja cipher"
        >
          <span>Ensiklopedia</span>
        </a>
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  {/* Main Content */}
  <main class="flex-1 w-full max-w-6xl mx-auto px-4 py-12 flex flex-col gap-10 items-center">
    {/* Hero Banner */}
    <div class="w-full max-w-4xl text-center flex flex-col items-center gap-4 py-8 px-6 rounded-3xl border-4 border-black dark:border-white bg-[#38bdf8] dark:bg-[#0369a1] text-black dark:text-white shadow-[8px_8px_0px_0px_#000000] dark:shadow-[8px_8px_0px_0px_#ffffff] relative overflow-hidden">
      <div class="absolute -right-10 -bottom-10 text-9xl opacity-10 select-none pointer-events-none font-black">
        LAB
      </div>
      <h2 class="font-black text-3xl sm:text-5xl uppercase tracking-tight max-w-2xl leading-tight">
        Kombinasi & Eksplorasi <span class="underline decoration-[#ffde59] decoration-4 underline-offset-4">Cipher Teks</span>
      </h2>
      <p class="font-bold text-sm sm:text-base max-w-xl text-black/90 dark:text-white/90">
        Transformasikan teks dengan mudah, aman di dalam browser Anda. Zero server-side processing, 100% privasi terjaga!
      </p>
      <div class="flex flex-wrap justify-center gap-2 mt-2">
        <span class="px-3 py-1 rounded-full border-2 border-black bg-[#ffde59] text-black font-extrabold text-xs shadow-[2px_2px_0px_0px_#000000]">
          ✅ Base64
        </span>
        <span class="px-3 py-1 rounded-full border-2 border-black bg-[#f472b6] text-black font-extrabold text-xs shadow-[2px_2px_0px_0px_#000000]">
          ✅ Caesar
        </span>
        <span class="px-3 py-1 rounded-full border-2 border-black bg-[#4ade80] text-black font-extrabold text-xs shadow-[2px_2px_0px_0px_#000000]">
          ✅ ROT13
        </span>
        <span class="px-3 py-1 rounded-full border-2 border-black bg-[#c084fc] text-black font-extrabold text-xs shadow-[2px_2px_0px_0px_#000000]">
          ✅ Vigenère
        </span>
        <span class="px-3 py-1 rounded-full border-2 border-black bg-[#38bdf8] text-black font-extrabold text-xs shadow-[2px_2px_0px_0px_#000000]">
          ✅ XOR
        </span>
        <span class="px-3 py-1 rounded-full border-2 border-black bg-[#ff5757] text-white font-extrabold text-xs shadow-[2px_2px_0px_0px_#000000]">
          🛡️ AES-256-GCM
        </span>
        <span class="px-3 py-1 rounded-full border-2 border-black bg-white text-black font-extrabold text-xs shadow-[2px_2px_0px_0px_#000000]">
          🔥 Mode Kombinasi (Pipeline Dnd)
        </span>
      </div>
    </div>

    {/* Interactive Encryptor Panel (React Island) */}
    <div class="w-full">
      <EncryptorPanel client:load />
    </div>

    
  </main>

  {/* Footer */}
  <footer class="w-full border-t-4 border-black dark:border-white bg-[#fbebcd] dark:bg-[#1a1a1a] py-6 px-4 mt-auto">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 font-bold text-xs">
      <p class="text-center sm:text-left">
        © 2026 <span class="font-black uppercase">{APP_NAME}</span>. Make with Love by <span class="px-2 py-0.5 rounded border border-black bg-[#ffde59] text-black font-extrabold">Mr. Baji</span>
      </p>
      <p class="text-gray-600 dark:text-gray-400">
        Arsitektur: <span class="font-extrabold text-black dark:text-white">Baji Arsitektur</span>
      </p>
    </div>
  </footer>
</BaseLayout>
